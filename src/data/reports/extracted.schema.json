{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chainsight.local/schemas/report-extracted.schema.json",
  "title": "ChainSight Report Extracted Data",
  "type": "object",
  "required": ["report", "metrics", "graphSignals", "companySignals", "timelineEvents"],
  "additionalProperties": false,
  "properties": {
    "report": {
      "type": "object",
      "required": ["id", "title", "type", "publishedAt", "sources"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "period": { "type": "string" },
        "publishedAt": { "type": "string" },
        "sources": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/metric" }
    },
    "graphSignals": {
      "type": "array",
      "items": { "$ref": "#/$defs/graphSignal" }
    },
    "companySignals": {
      "type": "array",
      "items": { "$ref": "#/$defs/companySignal" }
    },
    "timelineEvents": {
      "type": "array",
      "items": { "$ref": "#/$defs/timelineEvent" }
    },
    "companyProductCoverage": {
      "type": "array",
      "items": { "$ref": "#/$defs/companyProductCoverage" }
    },
    "productGrowthInputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/productGrowthInput" }
    },
    "products": {
      "type": "array",
      "items": { "$ref": "#/$defs/product" }
    },
    "productCategoryMetrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/productCategoryMetric" }
    },
    "notes": {
      "$ref": "#/$defs/reportNotes"
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": ["id", "label", "value", "unit", "period"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "period": { "type": "string" },
        "yoy": { "type": "number" },
        "derived": { "type": "boolean" },
        "formula": { "type": "string" }
      }
    },
    "graphSignal": {
      "type": "object",
      "required": ["id", "target", "metric", "value", "unit", "period", "confidence", "method"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "target": {
          "oneOf": [
            {
              "type": "object",
              "required": ["type", "id"],
              "properties": {
                "type": { "const": "node" },
                "id": { "type": "string" }
              }
            },
            {
              "type": "object",
              "required": ["type", "source", "target"],
              "properties": {
                "type": { "const": "edge" },
                "source": { "type": "string" },
                "target": { "type": "string" }
              }
            }
          ]
        },
        "metric": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "period": { "type": "string" },
        "estimated": { "type": "boolean" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "method": { "type": "string" },
        "sourceMetricIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "companySignal": {
      "type": "object",
      "required": ["id", "companyId", "period", "fields", "confidence", "method"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "period": { "type": "string" },
        "fields": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "layer": { "type": "string" },
            "techRoute": { "type": "string" },
            "stage": { "type": "string" },
            "massProductionEta": { "type": "string" },
            "keyCustomers": {
              "type": "array",
              "items": { "type": "string" }
            },
            "relatedNodeIds": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "estimated": { "type": "boolean" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "method": { "type": "string" },
        "sourceMetricIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "timelineEvent": {
      "type": "object",
      "required": ["id", "date", "type", "title", "summary", "sourceReportId"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "relatedNodeIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "relatedCompanyIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sourceReportId": { "type": "string" }
      }
    },
    "companyProductCoverage": {
      "type": "object",
      "required": [
        "companyId",
        "productNodeId",
        "coverageEvidenceType",
        "coverageSource",
        "evidenceText",
        "isRevenueProduct",
        "notes"
      ],
      "additionalProperties": true,
      "properties": {
        "companyId": { "type": "string" },
        "productNodeId": { "type": "string" },
        "coverageEvidenceType": { "type": "string" },
        "coverageSource": { "type": "string" },
        "evidenceText": { "type": "string" },
        "isRevenueProduct": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "productGrowthInput": {
      "type": "object",
      "required": [
        "id",
        "companyId",
        "productNodeId",
        "period",
        "growthMetricId",
        "growthValue",
        "growthValueType",
        "revenueScope",
        "scopeLabel",
        "shareOfScope",
        "managementAttribution",
        "hasProductRevenueAmount",
        "hasProductRevenueGrowth",
        "sourceMetricIds",
        "graphTarget",
        "notes"
      ],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "productNodeId": { "type": "string" },
        "period": { "type": "string" },
        "growthMetricId": { "type": "string" },
        "growthValue": { "type": ["number", "null"] },
        "growthValueType": { "type": "string" },
        "revenueScope": { "type": "string" },
        "scopeLabel": { "type": "string" },
        "shareOfScope": { "type": "string" },
        "managementAttribution": { "type": "string" },
        "attributionEvidenceText": { "type": "string" },
        "hasProductRevenueAmount": { "type": "boolean" },
        "hasProductRevenueGrowth": { "type": "boolean" },
        "sourceMetricIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "graphTarget": {
          "oneOf": [
            {
              "type": "object",
              "required": ["type", "id"],
              "properties": {
                "type": { "const": "node" },
                "id": { "type": "string" }
              }
            },
            {
              "type": "object",
              "required": ["type", "source", "target"],
              "properties": {
                "type": { "const": "edge" },
                "source": { "type": "string" },
                "target": { "type": "string" }
              }
            }
          ]
        },
        "notes": { "type": "string" }
      }
    },
    "product": {
      "type": "object",
      "required": ["productNodeId", "coverage"],
      "additionalProperties": true,
      "properties": {
        "productNodeId": { "type": "string" },
        "coverage": {
          "type": "object",
          "required": ["evidenceType", "source", "evidenceText", "commercializationType", "isRevenueProduct", "notes"],
          "additionalProperties": true,
          "properties": {
            "evidenceType": { "type": "string" },
            "source": { "type": "string" },
            "evidenceText": { "type": "string" },
            "commercializationType": { "type": "string" },
            "isRevenueProduct": { "type": "boolean" },
            "notes": { "type": "string" }
          }
        },
        "financial": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["target", "salesStatus", "edgeAttribution", "evidenceText", "sourceMetricIds", "notes"],
            "additionalProperties": true,
            "properties": {
              "target": { "type": "string" },
              "salesStatus": { "type": "string" },
              "edgeAttribution": { "type": "string" },
              "evidenceText": { "type": "string" },
              "sourceMetricIds": {
                "type": "array",
                "items": { "type": "string" }
              },
              "notes": { "type": "string" }
            }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "productCategoryMetric": {
      "type": "object",
      "required": ["id", "categoryName", "period", "unit", "sourceSection", "sourceText", "mappedNodeIds", "notes"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "categoryName": { "type": "string" },
        "period": { "type": "string" },
        "revenue": { "type": ["number", "null"] },
        "operatingCost": { "type": ["number", "null"] },
        "grossProfit": { "type": ["number", "null"] },
        "grossMargin": { "type": ["number", "null"] },
        "revenueYoy": { "type": ["number", "null"] },
        "operatingCostYoy": { "type": ["number", "null"] },
        "grossProfitYoy": { "type": ["number", "null"] },
        "grossMarginChangePpt": { "type": ["number", "null"] },
        "unit": { "type": "string" },
        "sourceSection": { "type": "string" },
        "sourceText": { "type": "string" },
        "mappedNodeIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    },
    "reportNotes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string" },
        "mappingAssumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
